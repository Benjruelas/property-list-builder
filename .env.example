# Web Push — generate keys: npx web-push generate-vapid-keys
# Use the same public key for both (Vite exposes VITE_* to the client).
VITE_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# mailto: URL required by Web Push (e.g. mailto:you@yourdomain.com)
VAPID_SUBJECT=mailto:notify@example.com

# Google Map Tiles API — latest high-res satellite imagery (same as maps.google.com)
# Use a Google Cloud API key with "Map Tiles API" enabled
# https://console.cloud.google.com/apis/library/tile.googleapis.com
GOOGLE_MAPS_TILES_KEY=

# Mapbox — high-res satellite imagery fallback (free: 200k tiles/mo)
# Sign up at https://mapbox.com → create a default public token
VITE_MAPBOX_ACCESS_TOKEN=

# LandRecords.us — nationwide parcel vector tiles
LANDRECORDS_API_KEY=
LANDRECORDS_TILE_URL=https://api.landrecords.us/pro/gwc/service/tms/1.0.0/pro:parcel_us@EPSG:3857x2@pbf

# Cloudflare R2 — tile cache (zero-egress re-serving)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=parcel-tiles

# Roof Inspector — Google Solar API (hi-res roof imagery)
GOOGLE_SOLAR_API_KEY=

# Roof Inspector — Copernicus Sentinel Hub (historical satellite imagery)
# Register at https://dataspace.copernicus.eu → Dashboard → OAuth clients
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=

# Roof Inspector — Anthropic Claude (AI vision analysis)
ANTHROPIC_API_KEY=

# Roof Inspector — EagleView Imagery API (oblique + orthogonal aerial images)
# Get your key at https://developer.eagleview.com
EAGLEVIEW_API_KEY=

# Skip tracing — Trestle IQ Reverse Address API (parcel address → residents + phones/emails)
# Get your key at https://trestleiq.com → API dashboard
TRESTLE_API_KEY=
