# Web Push — generate keys: npx web-push generate-vapid-keys
# Use the same public key for both (Vite exposes VITE_* to the client).
VITE_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# mailto: URL required by Web Push (e.g. mailto:you@yourdomain.com)
VAPID_SUBJECT=mailto:notify@example.com

# LandRecords.us — nationwide parcel vector tiles
LANDRECORDS_API_KEY=
LANDRECORDS_TILE_URL=https://api.landrecords.us/pro/gwc/service/tms/1.0.0/pro:parcel_us@EPSG:3857x2@pbf

# Cloudflare R2 — tile cache (zero-egress re-serving)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=parcel-tiles

# Roof Inspector — Google Solar API (hi-res roof imagery)
GOOGLE_SOLAR_API_KEY=

# Roof Inspector — Copernicus Sentinel Hub (historical satellite imagery)
# Register at https://dataspace.copernicus.eu → Dashboard → OAuth clients
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=

# Roof Inspector — Anthropic Claude (AI vision analysis)
ANTHROPIC_API_KEY=
